# Render outputs (regenerate with the CLI; never commit sheets/PNGs).
generated/
output/
*.png

# Differential-harness baselines + iteration scratch (see parity_harness.py).
.parity-baseline/
agent-scratch/

# Per-sheet regen cache (regen_sprites.sh).
.cache/

# Local Godot editor/runtime binaries.
tpl/Godot_v*-stable_linux.x86_64

# Python
__pycache__/
*.egg-info/
.venv/

# Local editor / IDE state
.vscode/
.idea/
*.swp
*.swo
*~

# OS junk
.DS_Store
Thumbs.db

# Logs, crash dumps, debug traces
*.log
*.dmp
debug_traces/

# Local env/config files
.env
.env.*
*.local

# Scratch dirs / backup artifacts
tmp/
temp/
*.bak
*.orig
*.rej

# Optional line_profiler reports (LINE_PROFILE=1 ./regen_sprites.sh).
.profiles/
*.lprof
profile_output*.txt
*.tar.gz
